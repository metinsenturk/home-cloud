# === DOMAIN & TIMEZONE ===
# Description: General system settings for the home cloud.
DOMAIN=yourdomain.com
TZ=UTC
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8

# === SYSTEM IDENTITY ===
# Description: Run 'id' in your terminal to find these values (standard is 1000)
PUID=1000
PGID=1000

# Description: The group ID for the 'docker' group on the host system. This allows apps to manage Docker if needed.
DOCKER_GROUP_ID=1001

# === MAKEFILE GROUP SETTINGS ===
# Description: Default backend for custom app groups in Makefile targets.
# Allowed values: make | yaml
# Default fallback in Makefile is 'make' if this is not set.
HOME_CLOUD_GROUPS_BACKEND=make

# === GLOBAL ADMIN CREDENTIALS ===
# Description: These credentials are for the global admin user of your home cloud.
HOME_CLOUD_EMAIL=admin@yourdomain.com
HOME_CLOUD_USERNAME=admin
HOME_CLOUD_PASSWORD=change_me_immediately

# === AUTHENTICATION SETTINGS ===
# Description: The base URL used to construct redirect URIs for individual apps
HOME_CLOUD_OAUTH_BASE_URL=http://${DOMAIN}

# Encryption Secrets (Used by apps for cookie/session signing)
# Used for signing cookies and encrypting session data across apps
# Generate these using a secure random generator (e.g., openssl rand -hex 16 for 32 chars)
# Example: 
# `openssl rand -hex 16` for a 32-character string, 
# `openssl rand -hex 32` for a 64-character string.
HOME_CLOUD_SESSION_SECRET=generate_a_random_32_char_string
HOME_CLOUD_JWT_SECRET=generate_a_random_64_char_string

# Google OAuth
GOOGLE_AUTH_CLIENT_ID=your-google-client-id
GOOGLE_AUTH_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_AUTH_CLIENT_ID=your-github-client-id
GITHUB_AUTH_CLIENT_SECRET=your-github-client-secret

# === INFRASTRUCTURE SECRETS ===
# Description: These are passwords of the shared infrastructure services. Use these
# variables in any app that needs to connect to the global Postgres instance.
INFRA_POSTGRES_PASSWORD=generate_a_strong_password
INFRA_MSSQL_PASSWORD=generate_a_strong_password

# === SMTP MAIL SETTINGS ===
# Description: Reusable outbound email settings for apps that send mail.
# Use SMTP_SECURE=true for implicit TLS (usually port 465). For STARTTLS (usually 587), set false.
HOME_CLOUD_SMTP_HOST=smtp.yourdomain.com
HOME_CLOUD_SMTP_PORT=587
HOME_CLOUD_SMTP_USERNAME=your-smtp-username
HOME_CLOUD_SMTP_PASSWORD=your-smtp-password
HOME_CLOUD_SMTP_SECURE=false
HOME_CLOUD_SMTP_FROM_EMAIL=no-reply@yourdomain.com
HOME_CLOUD_SMTP_FROM_NAME=Home Cloud

# === EXTERNAL API KEYS ===
# Description: API keys for external services. 
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GITHUB_TOKEN==your-github-token-here