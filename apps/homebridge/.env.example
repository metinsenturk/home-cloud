# Homebridge Local Environment Variables
# These values are inherited from the root .env via the Makefile's "Double-Env" pattern

# Timezone (inherited from global TZ)
TZ=${TZ}

# User and Group IDs for file permissions (inherited from global PUID/PGID)
PUID=${PUID}
PGID=${PGID}

# Domain for Traefik routing (inherited from global DOMAIN)
DOMAIN=${DOMAIN}
