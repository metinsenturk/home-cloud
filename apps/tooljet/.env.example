# ToolJet Application Configuration
# This file contains environment variables for the ToolJet application.
# These variables are service-specific and not inherited from the root .env.

# ============================================
# Database Configuration
# ============================================
# PostgreSQL runs as a dedicated service (tooljet-db) in this compose stack
# The database is isolated to this ToolJet application
TOOLJET_PG_HOST=tooljet-db
TOOLJET_PG_DB=tooljet
TOOLJET_PG_USER=tooljet
TOOLJET_PG_PASS=your_secure_tooljet_db_password_here

# Redis Configuration (required when using a separate worker container)
TOOLJET_REDIS_HOST=tooljet-redis
TOOLJET_REDIS_PORT=6379

# Worker Configuration (workflow scheduling)
TOOLJET_WORKFLOW_CONCURRENCY=5

# Internal ToolJet database name
TOOLJET_DB_NAME=tooljet_db

# ============================================
# PostgREST Configuration
# ============================================
# PostgREST provides a RESTful API interface to the PostgreSQL database
# Accessible at: http://tooljet-api.${DOMAIN}
# The PGRST_JWT_SECRET is shared with ToolJet for token validation

# ============================================
# Encryption & Security Keys
# ============================================
# IMPORTANT: Generate these using the commands below:
# LOCKBOX_MASTER_KEY (32-byte hex): openssl rand -hex 32
# SECRET_KEY_BASE (64-byte hex): openssl rand -hex 64
# PGRST_JWT_SECRET (32-byte hex): openssl rand -hex 32

TOOLJET_LOCKBOX_KEY=your_generated_lockbox_key_here
TOOLJET_SECRET_KEY=your_generated_secret_key_here
TOOLJET_PGRST_JWT_SECRET=your_generated_pgrst_jwt_secret_here

# ============================================
# Global Variable Mappings
# ============================================
# These reference global variables from the root .env
# DOMAIN and TZ are provided by the root .env via Makefile
