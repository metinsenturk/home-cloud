# NocoDB Admin Credentials - maps to global HOME_CLOUD_EMAIL and HOME_CLOUD_PASSWORD
NC_ADMIN_EMAIL=${HOME_CLOUD_EMAIL}
NC_ADMIN_PASSWORD=${HOME_CLOUD_PASSWORD}

# NocoDB JWT Secret - MUST be unique and complex for security
# Generate a secure random string (e.g., openssl rand -hex 32)
NC_AUTH_JWT_SECRET=your-random-jwt-secret-here

# PostgreSQL Configuration for NocoDB's internal database
POSTGRES_USER=nocodb
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=nocodb
