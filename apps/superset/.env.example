# Superset Application Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration (PostgreSQL)
DATABASE_DIALECT=postgresql
DATABASE_USER=superset
DATABASE_PASSWORD=your_strong_password_here
DATABASE_HOST=superset-postgres
DATABASE_PORT=5432
DATABASE_DB=superset

# Redis Configuration
REDIS_HOST=superset-redis
REDIS_PORT=6379

# Superset Secret Key (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(42))")
SUPERSET_SECRET_KEY=your_generated_secret_key_here

# Load example data (set to 'yes' to include sample dashboards, 'no' to skip)
SUPERSET_LOAD_EXAMPLES=no
