# Blinko Database Configuration
BLINKO_DB_PASSWORD=your_secure_database_password_here

# NextAuth Configuration
# Generate using: openssl rand -hex 32
BLINKO_NEXTAUTH_SECRET=generate_a_64_character_random_string_for_nextauth

# Global variables (inherited from root .env via Makefile)
# These are automatically loaded - do not modify
TZ=${TZ}
DOMAIN=${DOMAIN}
