# Blinko Database Configuration
BLINKO_DB_NAME=blinko
BLINKO_DB_USER=postgres
BLINKO_DB_PASSWORD=your_secure_database_password_here

# NextAuth Configuration
# Generate using: openssl rand -hex 32
BLINKO_NEXTAUTH_SECRET=generate_a_64_character_random_string_for_nextauth

# AI Integration (Optional)
# These are optional - only set if you want to use these AI providers
BLINKO_OPENAI_API_KEY=sk-your-openai-api-key-here
BLINKO_GEMINI_API_KEY=your-google-gemini-api-key-here
BLINKO_OPENROUTER_API_KEY=your-openrouter-api-key-here

# Global variables (inherited from root .env via Makefile)
# These are automatically loaded - do not modify
TZ=${TZ}
DOMAIN=${DOMAIN}
