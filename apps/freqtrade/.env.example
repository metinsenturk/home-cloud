# PostgreSQL Database Configuration
# Local variables for freqtrade's dedicated PostgreSQL instance
FREQTRADE_POSTGRES_USER=freqtrade
FREQTRADE_POSTGRES_PASSWORD=change_this_to_a_secure_password
FREQTRADE_POSTGRES_DB=freqtrade

# API Server Credentials
# Used for FreqUI access and REST API authentication
FREQTRADE_API_USERNAME=freqtrader
FREQTRADE_API_PASSWORD=change_this_to_a_secure_password

# JWT and WebSocket Tokens
# Generate secure tokens with: python3 -c "import secrets; print(secrets.token_hex(32))"
FREQTRADE_JWT_SECRET=change_this_to_a_32_character_secure_token
FREQTRADE_WS_TOKEN=change_this_to_a_secure_websocket_token

# Global Variables (inherited from root .env via Makefile)
# The following variables are automatically inherited from the root .env:
# - DOMAIN: Your domain name (e.g., example.com)
# - TZ: Timezone setting
# - PUID/PGID: User and group IDs for file permissions
