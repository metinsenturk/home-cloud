# === MAILPIT CONFIGURATION ===
# Description: Email testing tool for capturing and viewing test emails

# Optional: Mailpit authentication (leave empty for no authentication)
# MP_UI_AUTH_USER=admin
# MP_UI_AUTH_PASS=your_secure_password

# Optional: Custom SMTP/HTTP bind addresses (defaults are fine for most use cases)
# MP_SMTP_BIND_ADDR=0.0.0.0:1025
# MP_UI_BIND_ADDR=0.0.0.0:8025

# Optional: Maximum number of messages to store (0 = unlimited)
# MP_MAX_MESSAGES=500

# Optional: Enable verbose logging
# MP_VERBOSE=false
