# Pi-hole Local Environment Variables
# These values are loaded after root .env via the Makefile's "Double-Env" pattern.

# Domain used by Traefik route label.
PIHOLE_DOMAIN=${DOMAIN}

# Timezone inherited from global settings.
PIHOLE_TZ=${TZ}

# Map to global admin password per platform convention.
PIHOLE_WEBPASSWORD=${HOME_CLOUD_PASSWORD}

# DNS host port for LAN clients.
PIHOLE_DNS_PORT=53

# Optional DHCP host port (keep disabled unless you enable DHCP in compose).
PIHOLE_DHCP_PORT=67

# Pi-hole's DNS listening mode.
# Default behavior is local-only request handling for safer installs.
# For Docker bridge networking, upstream docs recommend ALL so requests forwarded
# from outside the container namespace are accepted correctly.
PIHOLE_DNS_LISTENING_MODE=ALL

# Upstream resolvers used by Pi-hole (semicolon-delimited list).
PIHOLE_DNS_UPSTREAMS=1.1.1.1;1.0.0.1

# Optional DHCP toggle (used only if FTLCONF_dhcp_active is uncommented in compose).
PIHOLE_ENABLE_DHCP=false

# Optional custom dnsmasq lines (semicolon-delimited list).
# Example: "address=/example.com/;address=/test.com/"
FTLCONF_misc_dnsmasq_lines=address=/hub.local/192.168.1.138