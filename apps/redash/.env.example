# Redash - Database Password (set to a strong password)
REDASH_DB_PASSWORD=your_strong_password_here

# Redash - Session/Cookie Secret (Generate with: openssl rand -hex 32)
REDASH_COOKIE_SECRET=generate_with_openssl_rand_hex_32

# Global variables inherited from root .env:
# - TZ
# - DOMAIN
# - HOME_CLOUD_SMTP_HOST
# - HOME_CLOUD_SMTP_PORT
# - HOME_CLOUD_SMTP_USERNAME
# - HOME_CLOUD_SMTP_PASSWORD
# - HOME_CLOUD_EMAIL
