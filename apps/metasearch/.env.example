# Metasearch Configuration
# Copy this file to .env and fill in your actual credentials

# Application Settings
METASEARCH_PORT=3000

# GitHub Configuration
# Create token at: https://github.com/settings/tokens (scope: repo)
METASEARCH_GITHUB_TOKEN=your_github_token_here
METASEARCH_GITHUB_ORG=your_org_name

# GitLab Configuration
# Create token at: https://gitlab.com/-/profile/personal_access_tokens (scopes: api, read_user, read_repository)
METASEARCH_GITLAB_TOKEN=your_gitlab_token_here
METASEARCH_GITLAB_ORIGIN=https://gitlab.com

# Slack Configuration
# Create app at: https://api.slack.com/apps (scopes: channels:read, search:read)
# Token format: xoxp-***
METASEARCH_SLACK_TOKEN=your_slack_token_here
METASEARCH_SLACK_ORG=your_workspace_name

# Jira Configuration
# Create token at: https://id.atlassian.com/manage-profile/security/api-tokens
METASEARCH_JIRA_TOKEN=your_jira_token_here
METASEARCH_JIRA_USER=your_email@example.com
METASEARCH_JIRA_ORIGIN=https://yourcompany.atlassian.net

# Confluence Configuration
# Use same API token as Jira
METASEARCH_CONFLUENCE_TOKEN=your_confluence_token_here
METASEARCH_CONFLUENCE_USER=your_email@example.com
METASEARCH_CONFLUENCE_ORIGIN=https://yourcompany.atlassian.net

# Notion Configuration
# Create integration at: https://www.notion.so/my-integrations
# Token format: secret_***
METASEARCH_NOTION_TOKEN=your_notion_token_here
METASEARCH_NOTION_WORKSPACE=your_workspace_id

# Jenkins Configuration (optional)
METASEARCH_JENKINS_ORIGIN=https://jenkins.example.com
METASEARCH_JENKINS_USER=your_jenkins_user
METASEARCH_JENKINS_TOKEN=your_jenkins_token

# Website Configuration
METASEARCH_WEBSITE_SITEMAP=https://www.apple.com/newsroom/sitemap.xml
