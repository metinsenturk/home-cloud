# Maps app-local password variable to the global Home Cloud admin password.
# This requires HOME_CLOUD_PASSWORD to be defined in the root .env.
DUPLICATI_PASSWORD=${HOME_CLOUD_PASSWORD}

# Restricts which Host headers the Duplicati web service accepts.
# Restriction: use explicit hostnames separated by ';' and avoid '*' unless you accept broad host access.
# Example for this stack:
DUPLICATI_ALLOWED_HOSTNAMES=duplicati.localhost
