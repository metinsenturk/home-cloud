# Reactive Resume Environment Variables

# Database Configuration
RESUME_DB_NAME=your_database_name
RESUME_DB_USER=your_database_user
RESUME_DB_PASSWORD=your_secure_database_password

# Application Authentication
RESUME_AUTH_SECRET=your_secure_auth_secret_key_minimum_32_characters

# Browserless Configuration
RESUME_BROWSERLESS_TOKEN=your_secure_browserless_token

# Application Features
# Set to 'true' to disable user signups (only existing users can log in)
FLAG_DISABLE_SIGNUPS=false
# Set to 'true' to disable email-based authentication
FLAG_DISABLE_EMAIL_AUTH=false

# S3 Storage Configuration (SeaweedFS)
RESUME_S3_ACCESS_KEY=your_s3_access_key
RESUME_S3_SECRET_KEY=your_s3_secret_key

# Global variables inherited from root .env:
# - TZ
# - DOMAIN
# - GITHUB_AUTH_CLIENT_ID
# - GITHUB_AUTH_CLIENT_SECRET
# - OPENAI_API_KEY
# - HOME_CLOUD_SMTP_HOST
# - HOME_CLOUD_SMTP_PORT
# - HOME_CLOUD_SMTP_USERNAME
# - HOME_CLOUD_SMTP_PASSWORD
# - HOME_CLOUD_SMTP_FROM_EMAIL
# - HOME_CLOUD_SMTP_FROM_NAME
# - HOME_CLOUD_SMTP_SECURE
