# Reactive Resume Environment Variables

# Database Configuration
RESUME_DB_NAME=your_database_name
RESUME_DB_USER=your_database_user
RESUME_DB_PASSWORD=your_secure_database_password

# Application Authentication
RESUME_AUTH_SECRET=your_secure_auth_secret_key_minimum_32_characters

# Browserless Configuration
RESUME_BROWSERLESS_TOKEN=your_secure_browserless_token

# S3 Storage Configuration (SeaweedFS)
RESUME_S3_ACCESS_KEY=your_s3_access_key
RESUME_S3_SECRET_KEY=your_s3_secret_key
