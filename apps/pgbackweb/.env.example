# pgBackweb Local Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL database credentials for pgBackweb metadata storage
PBW_DB_USER=pgbackweb
PBW_DB_PASSWORD=your_secure_password_here
PBW_DB_NAME=pgbackweb_db

# Encryption key for sensitive backup data - MUST be a strong random value
# Generate with: openssl rand -base64 32
PBW_ENCRYPTION_KEY=your_encryption_key_here

# PostgreSQL connection string for pgBackweb to store its metadata
# Format: postgresql://user:password@host:port/database?sslmode=disable
# Update with your actual credentials and database name
PBW_POSTGRES_CONN_STRING=postgresql://pgbackweb:your_secure_password_here@pgbackweb-db:5432/pgbackweb_db?sslmode=disable
