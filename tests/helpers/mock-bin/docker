#!/usr/bin/env bash
# Mock docker CLI used by Makefile unit-like tests.
#
# Purpose:
# - Prevent tests from invoking the real Docker daemon.
# - Return success for Docker subcommands used by the Makefile recipes.
#
# Behavior:
# - Accepts `docker network inspect`, `docker network create`, and `docker compose`.
# - Supports env flags for failure simulation in tests:
#   - MOCK_DOCKER_NETWORK_INSPECT_FAIL=1
#   - MOCK_DOCKER_COMPOSE_CONFIG_FAIL=1
# - Supports command logging for assertions:
#   - MOCK_DOCKER_LOG_FILE=/path/to/log
set -e

# Optionally log every docker invocation for test assertions.
if [[ -n "${MOCK_DOCKER_LOG_FILE:-}" ]]; then
  {
    printf 'docker'
    for arg in "$@"; do
      printf '\t%s' "$arg"
    done
    printf '\n'
  } >> "$MOCK_DOCKER_LOG_FILE"
fi

# Simulate successful network existence check.
if [[ "$1" == "network" && "$2" == "inspect" ]]; then
  if [[ "${MOCK_DOCKER_NETWORK_INSPECT_FAIL:-0}" == "1" ]]; then
    exit 1
  fi
  exit 0
fi

# Simulate successful network creation.
if [[ "$1" == "network" && "$2" == "create" ]]; then
  exit 0
fi

# Simulate successful docker compose invocation.
if [[ "$1" == "compose" ]]; then
  if [[ "${MOCK_DOCKER_COMPOSE_CONFIG_FAIL:-0}" == "1" ]]; then
    for arg in "$@"; do
      if [[ "$arg" == "config" ]]; then
        exit 1
      fi
    done
  fi
  exit 0
fi

# Default success fallback for unsupported/extra invocations in tests.
exit 0
